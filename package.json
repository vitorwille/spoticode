{
  "name": "spoticode",
  "displayName": "Spoticode - Spotify Miniplayer no VS Code",
  "description": "Controle o Spotify diretamente no VS Code. Selecione músicas, playlists, pause e muito mais sem fechar o VSCode.",
  "version": "1.1.0",
  "publisher": "vitorwille",
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "resources/spoticode-logo.png",
  "galleryBanner": {
    "color": "#1DB954",
    "theme": "dark"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "spotify",
    "spoticode",
    "music",
    "player",
    "miniplayer",
    "productivity",
    "songs",
    "remote"
  ],
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/vitorwille/spoticode"
  },
  "bugs": {
    "url": "https://github.com/vitorwille/spoticode/issues"
  },
  "homepage": "https://github.com/vitorwille/spoticode#readme",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "spoticode-sidebar",
          "title": "Spoticode - Miniplayer",
          "icon": "resources/spoticode-logo.png"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "icon": "resources/spoticode-logo.png",
          "type": "webview",
          "id": "spoticode.miniplayer",
          "name": "Spoticode - Miniplayer"
        }
      ]
    },
    "configuration": {
      "title": "Spoticode",
      "properties": {
        "spoticode.clientId": {
          "type": "string",
          "default": "",
          "description": "Spotify - Client ID"
        }
      }
    },
    "commands": [
      {
        "command": "spoticode.login",
        "title": "Spoticode: Logar no Spotify"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "npm run compile"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "randomstring": "^1.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.20.2",
    "typescript": "^5.4.5"
  },
  "badges": [
    {
      "url": "https://vsmarketplacebadges.dev/version-short/vitorwille.spoticode.svg",
      "href": "https://marketplace.visualstudio.com/items?itemName=vitorwille.spoticode",
      "description": "Marketplace Version"
    },
    {
      "url": "https://img.shields.io/visual-studio-marketplace/i/vitorwille.spoticode?color=1DB954",
      "href": "https://marketplace.visualstudio.com/items?itemName=vitorwille.spoticode",
      "description": "Installs"
    }
  ]
}